{
  "name": "terminal-bridge",
  "version": "2.3.0",
  "description": "Plugin reutilizável: liga o chat de um site ao Claude Code local (na máquina do owner), via Supabase Realtime. Inclui Presence (online/offline), printscreen e continuidade de sessão. Melhora-se uma vez, vale para todos os sites.",
  "type": "module",
  "license": "MIT",
  "author": "Samuel Castro",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "terminal-bridge": "./bin/cli.mjs"
  },
  "files": [
    "dist",
    "daemon",
    "bin",
    "scripts",
    "sites.example.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "daemon": "bun daemon/terminal-bridge.mjs",
    "release": "node scripts/release.mjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "@supabase/supabase-js": ">=2"
  },
  "dependencies": {
    "modern-screenshot": "^4.7.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "supabase",
    "realtime",
    "chat",
    "bridge"
  ]
}
